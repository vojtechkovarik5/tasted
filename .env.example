# Copy to .env. Consumed by:
#   - docker compose (variable substitution for the db + api services)
#   - the app when run locally without Docker (pydantic-settings)
#
# NOTE: for local (non-Docker) runs, POSTGRES_HOST must be localhost.
# Inside Docker the api service overrides POSTGRES_HOST to "db" itself.
POSTGRES_USER=tasted
POSTGRES_PASSWORD=tasted
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tasted

# Celery broker. Inside Docker the services override REDIS_HOST to "redis"
# and use in-network port 6379; 6380 is the host-published port of the
# compose redis (6379 on the host is often taken by another local redis).
REDIS_HOST=localhost
REDIS_PORT=6380

APP_ENV=local

# --- Clerk (auth) ---------------------------------------------------------
# Leave blank for local dev: every request resolves to a fixed dev user.
# Set CLERK_JWKS_URL to turn on real JWT verification.
CLERK_JWKS_URL=
CLERK_SECRET_KEY=

# --- Object storage (menu photos, user dish photos) -----------------------
# Leave S3_BUCKET blank for local dev: uploads go to ./backend/uploads.
# For AWS set bucket + region + creds. For Cloudflare R2 / MinIO also set
# AWS_ENDPOINT_URL, and S3_PUBLIC_BASE_URL to your CDN origin.
S3_BUCKET=
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=
S3_PUBLIC_BASE_URL=

# --- OpenAI (LLM extraction/enrichment) -----------------------------------
# Leave blank for local dev: the pipeline uses the deterministic stub AI.
OPENAI_API_KEY=
