# Copy to mobile/.env and set the backend URL your device can reach.
# Expo automatically loads variables prefixed with EXPO_PUBLIC_.
#
#   iOS simulator (on the Mac):   http://localhost:8000
#   Android emulator:             http://10.0.2.2:8000
#   Physical phone (Expo Go):     http://<your-computer-LAN-IP>:8000
#
# Find your Mac's LAN IP with:  ipconfig getifaddr en0
EXPO_PUBLIC_API_URL=http://localhost:8000

# Clerk (auth) — from https://dashboard.clerk.com -> API keys.
# Needed once @clerk/clerk-expo is wired in (see README "Auth" section).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
